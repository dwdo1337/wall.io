# Optional. This backend needs no API keys to function — GMGN scraping is
# free and keyless. PORT is set automatically by most hosts (Render, Fly,
# Railway); only set it yourself for local testing.
PORT=3001
DEBUG=0

# Optional: Helius API key for fallback when GMGN is blocked.
# Get a free key at https://helius.dev — free tier covers ~100k requests/month.
# If set here, the backend uses Helius automatically when GMGN fails.
# Users can also set this per-install via the extension popup (stored locally).
# HELIUS_API_KEY=helius-your-key-here
